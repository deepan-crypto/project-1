{
  "expo": {
    "name": "Thoughts",
    "slug": "crypto-app",
    "version": "1.0.0",

    "android": {
      "package": "com.deepangokul.cryptoapp",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "NOTIFICATIONS"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "thoughts.co.in",
              "pathPrefix": "/poll"
            },
            {
              "scheme": "https",
              "host": "thoughts.co.in",
              "pathPrefix": "/profile"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },

    "orientation": "portrait",
    "icon": "./assets/images/ican.png",
    "scheme": "thoughts",

    "splash": {
      "image": "./assets/images/ican.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },

    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.deepangokul.cryptoapp"
    },

    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },

    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-secure-store",

      [
        "expo-notifications",
        {
          "icon": "./assets/images/ican.png",
          "color": "#458FD0"
        }
      ],

      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ]
    ],

    "experiments": {
      "typedRoutes": true
    },

    "extra": {
      "router": {},
      "eas": {
        "projectId": "a4ffd402-6a05-4947-aca4-532add267f61"
      }
    },

    "owner": "deepang1902"
  }
}