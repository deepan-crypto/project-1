# ===========================================
# Thoughts Backend - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values

# Server
PORT=5000
NODE_ENV=development
ADMIN_SECRET_TOKEN=your_secure_admin_token_here

# MongoDB
MONGODB_URI=mongodb://localhost:27017/polling-app

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d

# Google OAuth (for login, NOT email)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# SendGrid Email Service
SENDGRID_API_KEY=SG.xxxxxxxxxxxx
SENDGRID_FROM_EMAIL=noreply@thoughts.co.in
SENDGRID_FROM_NAME=Thoughts

# Contact Form
CONTACT_FORM_TO_EMAIL=support@thoughts.co.in

# App
APP_NAME=Thoughts
FRONTEND_URL=myapp://auth
